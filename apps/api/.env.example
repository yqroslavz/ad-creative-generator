NODE_ENV=development
PORT=4000

# Supabase Transaction pooler (port 6543) for runtime, requires ?pgbouncer=true&connection_limit=1.
DATABASE_URL="postgresql://acg:acg@localhost:5432/acg?schema=public"
# Supabase Session pooler (port 5432) for migrations (prisma migrate / db push need direct/session conn).
DIRECT_URL="postgresql://acg:acg@localhost:5432/acg?schema=public"

# Clerk: dashboard → API keys
CLERK_SECRET_KEY=sk_test_...
# Clerk: dashboard → Webhooks → Signing secret
CLERK_WEBHOOK_SECRET=whsec_...

# 32-byte master key for BYOK AES-256-GCM. Generate with: openssl rand -base64 32
# NEVER commit. Set in Render dashboard before first BYOK use (week 5).
ENCRYPTION_KEY=

# Local dev (docker-compose) — keep as-is. Production: Upstash Redis URL.
# BullMQ requires maxRetriesPerRequest: null on the connection (see Gotchas).
REDIS_URL=redis://localhost:6379

# Google AI Studio → API key. Used as demo-mode default text provider (week 3).
GEMINI_SYSTEM_KEY=

# Public URL of the Next.js frontend; used for CORS allowlist.
WEB_APP_URL=http://localhost:3000

# Stripe (TEST MODE ONLY). Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_...
# Printed by `stripe listen --forward-to localhost:4000/stripe/webhook` during local dev.
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs of the monthly subscription tiers created in the Stripe dashboard (test mode).
STRIPE_PRICE_TIER_BASIC=price_...
STRIPE_PRICE_TIER_PRO=price_...
