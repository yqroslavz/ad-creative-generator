NODE_ENV=development
PORT=4000

# Local dev (docker-compose): keep as-is.
# Production (Supabase): use the POOLED connection string with `?pgbouncer=true&connection_limit=1`.
# See PROJECT_SPEC.md Gotchas section.
DATABASE_URL="postgresql://acg:acg@localhost:5432/acg?schema=public"

# Clerk: dashboard → API keys
CLERK_SECRET_KEY=sk_test_...
# Clerk: dashboard → Webhooks → Signing secret
CLERK_WEBHOOK_SECRET=whsec_...

# 32-byte master key for BYOK AES-256-GCM. Generate with: openssl rand -base64 32
# NEVER commit. Set in Render dashboard before first BYOK use (week 5).
ENCRYPTION_KEY=

# Local dev (docker-compose) — keep as-is. Production: Upstash Redis URL.
# BullMQ requires maxRetriesPerRequest: null on the connection (see Gotchas).
REDIS_URL=redis://localhost:6379

# Google AI Studio → API key. Used as demo-mode default text provider (week 3).
GEMINI_SYSTEM_KEY=

# Public URL of the Next.js frontend; used for CORS allowlist.
WEB_APP_URL=http://localhost:3000
